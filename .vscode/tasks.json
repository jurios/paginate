{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Ruff Check",
      "type": "shell",
      "command": "uv run --no-sync ruff check .",
      "presentation": {
        "panel": "dedicated",
        "group": "checks",
        "reveal": "always"
      },
    },
    {
      "label": "Ruff Format Check",
      "type": "shell",
      "command": "uv run --no-sync ruff format --check .",
      "presentation": {
        "panel": "dedicated",
        "group": "checks",
        "reveal": "always"
      },
      "problemMatcher": [],
    },
    {
      "label": "Run All Checks",
      "dependsOn": ["Ruff Check", "Ruff Format Check"],
      "dependsOrder": "parallel",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": [],
    },
  ]
}